{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service",
    "description": "Cleaning services — unified 7-section template for all service types"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "serviceType": {
      "type": "enumeration",
      "enum": ["routine", "deep", "airbnb", "moving", "post-construction", "office", "medical", "gym", "retail", "school", "property", "extras", "other-commercial"],
      "required": true
    },
    "heroTopLabel": {
      "type": "string"
    },
    "heroHeading": {
      "type": "string",
      "required": true
    },
    "heroSubheading": {
      "type": "text"
    },
    "heroBackgroundImage": {
      "type": "media",
      "allowedTypes": ["images"],
      "multiple": false
    },
    "heroBackgroundImageUrl": {
      "type": "string"
    },
    "heroServiceDuration": {
      "type": "string"
    },
    "heroServiceGuarantee": {
      "type": "string",
      "default": "100% Satisfaction"
    },
    "serviceTrustIndicators": {
      "type": "component",
      "repeatable": true,
      "component": "content.service-trust-indicator"
    },
    "includedSectionHeading": {
      "type": "string"
    },
    "includedSectionSubheading": {
      "type": "text"
    },
    "cleaningAreas": {
      "type": "component",
      "repeatable": true,
      "component": "content.cleaning-area"
    },
    "whyChooseHeading": {
      "type": "string"
    },
    "whyChooseSubheading": {
      "type": "text"
    },
    "benefit1Title": {
      "type": "string"
    },
    "benefit1Description": {
      "type": "text"
    },
    "benefit1Icon": {
      "type": "string"
    },
    "benefit2Title": {
      "type": "string"
    },
    "benefit2Description": {
      "type": "text"
    },
    "benefit2Icon": {
      "type": "string"
    },
    "benefit3Title": {
      "type": "string"
    },
    "benefit3Description": {
      "type": "text"
    },
    "benefit3Icon": {
      "type": "string"
    },
    "clientTestimonialsHeading": {
      "type": "string",
      "default": "What Our Clients Say"
    },
    "clientTestimonialsSubheading": {
      "type": "text"
    },
    "clientTestimonials": {
      "type": "component",
      "repeatable": true,
      "component": "content.testimonial"
    },
    "faqs": {
      "type": "component",
      "repeatable": true,
      "component": "content.faq-item"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "openGraph": {
      "type": "component",
      "repeatable": false,
      "component": "shared.open-graph"
    },
    "scripts": {
      "type": "component",
      "repeatable": false,
      "component": "shared.script-injection"
    },
    "schema": {
      "type": "component",
      "repeatable": false,
      "component": "shared.schema-template"
    },
    "excludeFromSitemap": {
      "type": "boolean",
      "default": false
    },
    "htmlBlocks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.html-block"
    }
  }
}
